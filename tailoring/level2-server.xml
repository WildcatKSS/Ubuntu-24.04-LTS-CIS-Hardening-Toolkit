<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tailoring file for the CIS Level 2 Server profile.

  This file is optional. When present, harden.sh/audit.sh load it automatically.

  Level 2 is significantly stricter than Level 1 and may affect the functionality
  of some services. Use this file to selectively disable controls that conflict
  with your specific environment.

  Generate a fully interactive starting point with:
    sudo usg generate-tailoring cis_level2_server tailoring/level2-server.xml

  Look up rule IDs via: sudo usg audit cis_level2_server 2>&1 | grep "Rule"
-->
<xccdf-1.2:Tailoring
    xmlns:xccdf-1.2="http://checklists.nist.gov/xccdf/1.2"
    id="xccdf_tailoring_level2_server">

  <xccdf-1.2:benchmark
      href="/usr/share/ubuntu-scap-security-guides/current/benchmarks/cis-ubuntu24-level2-server.xml"/>

  <xccdf-1.2:version time="2026-01-01T00:00:00" update=""/>

  <xccdf-1.2:Profile
      id="xccdf_tailoring_profile_level2_server"
      extends="xccdf_org.ssgproject.content_profile_cis_level2_server">

    <xccdf-1.2:title>Customised CIS Level 2 Server</xccdf-1.2:title>
    <xccdf-1.2:description>
      Local adjustments to the CIS Level 2 Server base profile.
      Level 2 requires careful evaluation per environment.
      Add select elements below to enable or disable specific controls.
    </xccdf-1.2:description>

    <!--
    Examples of common Level 2 exceptions:

    SELinux enforcing (when you use AppArmor instead of SELinux):
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_selinux_state" selected="false"/>

    Time synchronisation via an internal NTP server (adjust instead of disable):
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_chronyd_server_directive" selected="false"/>
    -->

  </xccdf-1.2:Profile>

</xccdf-1.2:Tailoring>
