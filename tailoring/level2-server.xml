<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tailoring-bestand voor CIS Level 2 Server profiel.

  Dit bestand is optioneel. Als het aanwezig is, laadt harden.sh/audit.sh het automatisch.

  Level 2 is aanzienlijk strenger dan Level 1 en kan de functionaliteit van sommige
  services beïnvloeden. Gebruik dit bestand om controls die conflicteren met jouw
  specifieke omgeving selectief uit te schakelen.

  Genereer een volledig interactief startpunt met:
    sudo usg generate-tailoring cis_level2_server tailoring/level2-server.xml

  Zoek rule-ID's op via: sudo usg audit cis_level2_server 2>&1 | grep "Rule"
-->
<Tailoring xmlns="http://checklists.nist.gov/xccdf/1.2"
           id="xccdf_cis-hardening-toolkit_tailoring_level2_server">

  <benchmark href="/usr/share/ubuntu-scap-security-guides/current/benchmarks/cis-ubuntu24-level2-server.xml"/>

  <version time="2026-01-01T00:00:00">1</version>

  <Profile id="xccdf_org.ssgproject.content_profile_cis_level2_server_customized"
           extends="xccdf_org.ssgproject.content_profile_cis_level2_server">

    <title xml:lang="en-US" override="true">Aangepast CIS Level 2 Server</title>
    <description xml:lang="en-US" override="true">
      Lokale aanpassingen op het CIS Level 2 Server basisprofiel.
      Level 2 vereist zorgvuldige afweging per omgeving.
      Voeg hieronder select-elementen toe om specifieke controls aan of uit te zetten.
    </description>

    <!--
    Voorbeelden voor veelvoorkomende Level 2 uitzonderingen:

    SELinux enforcing (als je AppArmor gebruikt i.p.v. SELinux):
    <select idref="xccdf_org.ssgproject.content_rule_selinux_state" selected="false"/>

    Tijdsynchronisatie via intern NTP-server (aanpassen i.p.v. uitschakelen):
    <select idref="xccdf_org.ssgproject.content_rule_chronyd_server_directive" selected="false"/>
    -->

  </Profile>

</Tailoring>
