<?xml version="1.0" encoding="UTF-8"?>
<!--
  Tailoring file for the CIS Level 1 Server profile.

  This file is optional. When present, harden.sh/audit.sh load it automatically.
  Use it to enable or disable specific CIS controls for your environment.

  Generate a fully customised starting point with:
    sudo usg generate-tailoring cis_level1_server tailoring/level1-server.xml

  You can then deactivate specific rules in the GUI and save the file.

  Manual editing:
  - Add <xccdf-1.2:select> elements inside the Profile block below.
  - selected="false" disables a control.
  - selected="true"  enables a control (already active in the base profile).

  Look up rule IDs via: sudo usg audit cis_level1_server 2>&1 | grep "Rule"
  or in the SCAP benchmark: /usr/share/ubuntu-scap-security-guides/current/benchmarks/
-->
<xccdf-1.2:Tailoring
    xmlns:xccdf-1.2="http://checklists.nist.gov/xccdf/1.2"
    id="xccdf_tailoring_level1_server">

  <xccdf-1.2:benchmark
      href="/usr/share/ubuntu-scap-security-guides/current/benchmarks/cis-ubuntu24-level1-server.xml"/>

  <xccdf-1.2:version time="2026-01-01T00:00:00" update=""/>

  <xccdf-1.2:Profile
      id="xccdf_tailoring_profile_level1_server"
      extends="xccdf_org.ssgproject.content_profile_cis_level1_server">

    <xccdf-1.2:title>Customised CIS Level 1 Server</xccdf-1.2:title>
    <xccdf-1.2:description>
      Local adjustments to the CIS Level 1 Server base profile.
      Add select elements below to enable or disable specific controls.
    </xccdf-1.2:description>

    <!--
    Examples:

    Disable a control (e.g. when you use a non-default SSH port):
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_sshd_set_loglevel_verbose" selected="false"/>

    Explicitly enable a control:
    <xccdf-1.2:select idref="xccdf_org.ssgproject.content_rule_package_aide_installed" selected="true"/>
    -->

  </xccdf-1.2:Profile>

</xccdf-1.2:Tailoring>
